# Copy this file to .env and fill in the values you need, then just run
# `streamlit run app.py` / `python src/fetch_satellite_features.py` normally --
# .env is loaded automatically (see satellite_features.py). Never commit
# your real .env -- .gitignore already excludes it.

# ------------------------------------------------------------------
# Required for LIVE Earth Engine data (HCHO map + satellite AQI map).
# Without this, both fall back to clearly-labeled simulated grids --
# the app still runs, just without real satellite pixels.
# ------------------------------------------------------------------

# Your Google Cloud project ID linked to Earth Engine (this is the
# usual missing piece even after `earthengine authenticate` succeeds --
# EE now requires a project). Find it at:
# https://console.cloud.google.com/ (top bar, next to "Google Cloud")
# or register one at https://code.earthengine.google.com/
EE_PROJECT=your-project-id

# ------------------------------------------------------------------
# ONLY needed for a service-account/headless deployment (e.g. hosting
# the dashboard on a server with no browser to run `earthengine
# authenticate` interactively). Leave both blank for local dev --
# `earthengine authenticate`'s cached login + EE_PROJECT above is enough.
# ------------------------------------------------------------------
EE_SERVICE_ACCOUNT=
EE_SERVICE_ACCOUNT_KEY=

# NASA FIRMS API Key for active fire observations
FIRMS_MAP_KEY=your-firms-map-key

