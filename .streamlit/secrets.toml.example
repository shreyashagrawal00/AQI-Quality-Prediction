# .streamlit/secrets.toml — Streamlit Cloud secrets template
# On Streamlit Cloud, add these under Settings → Secrets
# For local dev, use .env instead (this file is git-ignored)

# ── Google Earth Engine (optional — app works without it in simulated mode) ──
EE_PROJECT = "your-google-cloud-project-id"

# For headless/cloud deployment without browser auth:
# EE_SERVICE_ACCOUNT = "your-service-account@project.iam.gserviceaccount.com"
# EE_SERVICE_ACCOUNT_KEY = """{ "type": "service_account", ... }"""

# ── NASA FIRMS fire data (optional) ──────────────────────────────────────────
FIRMS_MAP_KEY = "your-firms-api-key"
